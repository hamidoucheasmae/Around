rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── User data: each user can only touch their own docs ──────────────
    match /users/{uid}/meta/progress {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    match /users/{uid}/meta/pair {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Account/premium: user can read their own; writes ONLY allowed when
    // premium field is not being self-elevated (must come via promo flow)
    match /users/{uid}/meta/account {
      allow read: if request.auth != null && request.auth.uid == uid;

      // Allow writes only when:
      //  - authenticated as the document owner, AND
      //  - the write does NOT introduce premium:true directly
      //    (premium can only be set by the promo activation path, which
      //     the client validates against promoCodes first — see below)
      allow write: if request.auth != null
        && request.auth.uid == uid
        && (
          // Writing premium=true is only allowed if a matching promo code exists
          // and is still active/unused
          (request.resource.data.get('premium', false) == true
            && request.resource.data.keys().hasAll(['premium','unlockedAt','promoCode'])
            && exists(/databases/$(database)/documents/promoCodes/$(request.resource.data.promoCode))
            && get(/databases/$(database)/documents/promoCodes/$(request.resource.data.promoCode)).data.active == true
            && get(/databases/$(database)/documents/promoCodes/$(request.resource.data.promoCode)).data.uses
               < get(/databases/$(database)/documents/promoCodes/$(request.resource.data.promoCode)).data.maxUses
          )
          // Or writing anything that doesn't touch the premium field at all
          || !request.resource.data.keys().hasAny(['premium'])
        );
    }

    // ── Pair codes: authenticated users can create their own, read any ──
    match /pairCodes/{code} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasOnly(['uid', 'createdAt']);
      allow update, delete: if false;
    }

    // ── Promo codes: authenticated users can read to validate ──
    // Only allow incrementing `uses` — no other field can change
    match /promoCodes/{code} {
      allow read: if request.auth != null;
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['uses'])
        && request.resource.data.uses == resource.data.uses + 1;
      allow create, delete: if false;
    }

    // ── Deny everything else ──────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
