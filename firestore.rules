rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /{document=**} {
      allow read, write: if false;
    }

    // Own user data
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Allow writing partnerUid to a partner's pair doc (pairing operation)
    match /users/{uid}/meta/pair {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null && (
        request.auth.uid == uid ||
        request.resource.data.keys().hasOnly(['partnerUid', 'pairedAt'])
      );
    }

    // Promo codes — read only
    match /promoCodes/{code} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Pair codes — full access for authenticated users
    match /pairCodes/{code} {
      allow read, write: if request.auth != null;
    }

    // Live sessions
    match /sessions/{sessionId} {
      allow read, write: if request.auth != null;
    }
  }
}
